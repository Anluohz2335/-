-- 日志区域 (Dex++ 核心布局)
local logFrame = Instance.new("ScrollingFrame")
logFrame.Size = UDim2.new(1, -4, 1, -65)
logFrame.Position = UDim2.new(0, 2, 0, 28)
logFrame.BackgroundTransparency = 1
logFrame.ScrollBarThickness = 3
logFrame.CanvasSize = UDim2.new(0, 0, 0, 0) -- 初始0
logFrame.Parent = main

-- 关键：用UIGridLayout代替UIListLayout，排版更精准，不会重叠
local layout = Instance.new("UIGridLayout")
layout.Parent = logFrame
layout.SortOrder = Enum.SortOrder.LayoutOrder
layout.CellSize = UDim2.new(1, 0, 0, 15) -- 固定每行15px高度
layout.Padding = UDim2.new(0, 0, 0, 1)   -- 1px间距

-- 手动控制Canvas高度，不依赖自动布局
local function updateCanvasHeight()
    local totalHeight = layout.AbsoluteContentSize.Y
    logFrame.CanvasSize = UDim2.new(0, 0, totalHeight, 0)
    
    -- 只有自动开启，且当前在最底部，才自动滚动
    if autoScroll then
        logFrame.CanvasPosition = Vector2.new(0, totalHeight)
    end
end

-- 日志输出函数
local function addLog(text, color)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 15) -- 必须和CellSize一致
    label.BackgroundTransparency = 1
    label.Text = "["..os.date("%H:%M:%S").."] "..text
    label.TextColor3 = color or Color3.new(0.9, 0.9, 0.9)
    label.Font = Enum.Font.Code
    label.TextSize = 11
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = logFrame
    
    -- 每次加日志都更新高度
    updateCanvasHeight()
end

-- 监听游戏输出
LogService.MessageOut:Connect(function(msg, msgType)
    local color = Color3.new(0.9, 0.9, 0.9)
    if msgType == Enum.MessageType.MessageWarning then color = Color3.new(1, 0.8, 0.2) end
    if msgType == Enum.MessageType.MessageError then color = Color3.new(1, 0.3, 0.3) end
    if msgType == Enum.MessageType.MessageInfo then color = Color3.new(0.2, 0.8, 1) end
    addLog(msg, color)
end)

