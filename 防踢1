-- 日志输出函数（核心：每次只增加固定高度）
local function addLog(text, color)
    -- 手动增加高度（和Dex一样，14px一行）
    local lineHeight = 14
    currentCanvasHeight += lineHeight
    logFrame.CanvasSize = UDim2.new(0, 0, currentCanvasHeight, 0)

    -- 创建文本
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, lineHeight)
    label.BackgroundTransparency = 1
    label.Text = "["..os.date("%H:%M:%S").."] "..text
    label.TextColor3 = color or Color3.new(0.9, 0.9, 0.9)
    label.Font = Enum.Font.Code
    label.TextSize = 11
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = logFrame

    -- 只有开了自动才会滚动
    if autoScroll then
        task.defer(function()
            logFrame.CanvasPosition = Vector2.new(0, currentCanvasHeight)
        end)
    end
end

-- 监听游戏输出
LogService.MessageOut:Connect(function(msg, msgType)
    local color = Color3.new(0.9, 0.9, 0.9)
    if msgType == Enum.MessageType.MessageWarning then
        color = Color3.new(1, 0.8, 0.2)
    elseif msgType == Enum.MessageType.MessageError then
        color = Color3.new(1, 0.3, 0.3)
    elseif msgType == Enum.MessageType.MessageInfo then
        color = Color3.new(0.2, 0.8, 1)
    end
    addLog(msg, color)
end)

-- 自动滚动开关
autoBtn.MouseButton1Click:Connect(function()
    autoScroll = not autoScroll
    autoBtn.Text = autoScroll and "自动: 开" or "自动: 关"
end)

-- 防踢开关
akBtn.MouseButton1Click:Connect(function()
    antiKickEnabled = not antiKickEnabled
    akBtn.Text = antiKickEnabled and "防踢: 开" or "防踢: 关"
    if antiKickEnabled then
        lp.Kick = function(...)
            kickCount += 1
            addLog("[防踢] 已拦截踢出（"..kickCount.."）", Color3.new(1, 0.5, 0.1))
            return task.wait(math.huge)
        end
    else
        lp.Kick = originalKick
    end
end)

-- 隐藏/显示
hideBtn.MouseButton1Click:Connect(function()
    main.Visible = false
    floatOpen.Visible = true
end)
floatOpen.MouseButton1Click:Connect(function()
    main.Visible = true
    floatOpen.Visible = false
end)

