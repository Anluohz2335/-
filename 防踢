-- ==============================================
-- 🛡️ 第四层：监控并拦截所有 RemoteEvent 踢出
-- ==============================================
local blockedRemoteNames = {
    "Kick", "kick", "KICK",
    "Ban", "ban", "BAN",
    "Punish", "punish",
    "Remove", "remove",
    "Destroy", "destroy"
}

-- 扫描并拦截远程事件
local function hookRemoteEvent(remote)
    if not remote:IsA("RemoteEvent") then return end
    
    local remoteName = remote.Name
    local shouldBlock = false
    
    for _, blockedName in ipairs(blockedRemoteNames) do
        if string.find(string.lower(remoteName), string.lower(blockedName)) then
            shouldBlock = true
            break
        end
    end
    
    if shouldBlock then
        local originalFireServer = remote.FireServer
        remote.FireServer = function(self, ...)
            if protection.enabled then
                protection.interceptCount += 1
                protection.remoteKickCount += 1
                addConsoleLog("[远程事件拦截] 阻止可疑远程调用: " .. remoteName, "WARN")
                return nil
            end
            return originalFireServer(self, ...)
        end
    end
end

-- 扫描所有现有的远程事件
local function scanForRemotes()
    for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
        pcall(function() hookRemoteEvent(obj) end)
    end
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        pcall(function() hookRemoteEvent(obj) end)
