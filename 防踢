-- 拦截详情记录
local interceptHistory = {}
local MAX_HISTORY = 10

function addInterceptHistory(eventType, details)
    table.insert(interceptHistory, 1, {
        Time = os.date("%H:%M:%S"),
        Type = eventType,
        Details = details
    })
    
    if #interceptHistory > MAX_HISTORY then
        table.remove(interceptHistory)
    end
    
    -- 更新显示
    local historyText = ""
    for _, record in ipairs(interceptHistory) do
        historyText = historyText .. string.format(
            "[%s] %s: %s\n",
            record.Time, record.Type, record.Details
        )
    end
    
    if historyText == "" then
        historyText = "暂无拦截记录"
    end
    
    DetailedStats:SetContent(historyText)
end

