-- ==============================================
-- 🛡️ 防踢核心（精简版）
-- ==============================================
local originalKick = lp.Kick
lp.Kick = function(self, reason, ...)
    if protection.enabled then
        protection.interceptCount += 1
        protection.localScriptKickCount += 1
        print("[防踢] 拦截踢出: " .. tostring(reason))
        return nil
    end
    return originalKick(self, reason, ...)
end

