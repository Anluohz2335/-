-- ==============================================
-- 🛡️ 第一层：拦截 LocalPlayer:Kick
-- ==============================================
local originalKick = lp.Kick
lp.Kick = function(self, reason, ...)
    if protection.enabled then
        protection.interceptCount += 1
        protection.localScriptKickCount += 1
        
        local kickReason = tostring(reason or "未知原因")
        addConsoleLog("[本地脚本拦截] 阻止踢出: " .. kickReason, "WARN")
        
        -- 可选：显示通知
        pcall(function()
            Rayfield:Notify({
                Title = "防踢系统",
                Content = "已拦截本地脚本踢出尝试",
                Duration = 3,
                Image = "shield"
            })
        end)
        
        return nil  -- 阻止踢出
    end
    return originalKick(self, reason, ...)
end

