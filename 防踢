local LogOutput = ConsoleTab:CreateParagraph({
    Title = "实时日志",
    Content = "✅ 全能防踢系统已启动..."
})

function addConsoleLog(message, logType)
    logType = logType or "INFO"
    local timestamp = os.date("%H:%M:%S")
    local prefix = "[" .. timestamp .. "] "
    
    local coloredMessage
    if logType == "ERROR" then
        coloredMessage = "❌ " .. message
    elseif logType == "WARN" then
        coloredMessage = "⚠️ " .. message
    elseif logType == "SUCCESS" then
        coloredMessage = "✅ " .. message
    else
        coloredMessage = "ℹ️ " .. message
    end
    
    pcall(function()
        LogOutput:SetContent(prefix .. coloredMessage .. "\n" .. LogOutput.Content)
    end)
    print("[防踢系统] [" .. logType .. "] " .. message)
end

