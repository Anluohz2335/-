frame.Position = UDim2.new(0.02, 0, 0.02, 0)
frame.BackgroundColor3 = Color3.new(0.07,0.07,0.1)
frame.BorderColor3 = Color3.new(0, 0.7, 1)
frame.BorderSizePixel = 2
frame.Parent = sg

-- 标题
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1,0,0,24)
title.BackgroundColor3 = Color3.new(0, 0.7, 1)
title.Text = "LOG CONSOLE | ANTI KICK"
title.TextColor3 = Color3.new(0,0,0)
title.Font = Enum.Font.Code
title.TextSize = 14
title.Parent = frame

-- 日志区域（重点：不自动跳到底部）
local logArea = Instance.new("ScrollingFrame")
logArea.Size = UDim2.new(1,-10,0.68,-24)
logArea.Position = UDim2.new(0,5,0,24)
logArea.BackgroundTransparency = 1
logArea.ScrollBarThickness = 6
logArea.ScrollingEnabled = true
logArea.Parent = frame

local list = Instance.new("UIListLayout")
list.Parent = logArea
list.SortOrder = Enum.SortOrder.LayoutOrder
list.Padding = UDim.new(0, 2)

-- 只自动改高度，不跳位置！
list:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
    logArea.CanvasSize = UDim2.new(0, 0, list.AbsoluteContentSize.Y + 20, 0)
end)

-- 状态
local status = Instance.new("TextLabel")
status.Size = UDim2.new(0.7,0,0.1,0)
status.Position = UDim2.new(0,5,0.72,0)
status.BackgroundTransparency = 1
status.Text = "ANTIKICK: OFF"
status.TextColor3 = Color3.new(1,0.2,0.2)
status.Font = Enum.Font.Code
status.TextSize = 13
status.Parent = frame

-- 防踢开关
local btnAntiKick = Instance.new("TextButton")
btnAntiKick.Size = UDim2.new(0.25,0,0.1,0)
btnAntiKick.Position = UDim2.new(0.7,0,0.72,0)
btnAntiKick.BackgroundColor3 = Color3.new(0.2,0.3,0.4)
btnAntiKick.Text = "START"
btnAntiKick.TextColor3 = Color3.new(1,1,1)
btnAntiKick.Font = Enum.Font.Code
btnAntiKick.TextSize = 13
btnAntiKick.Parent = frame

-- 日志开关（你要的）
local btnLogToggle = Instance.new("TextButton")
btnLogToggle.Size = UDim2.new(0.4,0,0.12,0)
btnLogToggle.Position = UDim2.new(0.05,0,0.84,0)
btnLogToggle.BackgroundColor3 = Color3.new(0.1,0.4,0.2)
btnLogToggle.Text = "LOG: ON"
btnLogToggle.TextColor3 = Color3.new(1,1,1)
btnLogToggle.Font = Enum.Font.Code
btnLogToggle.TextSize = 13
btnLogToggle.Parent = frame

-- 清空日志按钮
local btnClearLog = Instance.new("TextButton")
btnClearLog.Size = UDim2.new(0.4,0,0.12,0)
btnClearLog.Position = UDim2.new(0.55,0,0.84,0)
btnClearLog.BackgroundColor3 = Color3.new(0.4,0.1,0.1)
btnClearLog.Text = "CLEAR LOG"
btnClearLog.TextColor3 = Color3.new(1,1,1)
btnClearLog.Font = Enum.Font.Code
btnClearLog.TextSize = 13
btnClearLog.Parent = frame

-- 窗口拖动
local drag, dragStart, framePos
frame.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then
        drag = true
        dragStart = i.Position
        framePos = frame.Position
    end
end)
frame.InputChanged:Connect(function(i)
    if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = i.Position - dragStart
        frame.Position = UDim2.new(framePos.X.Scale, framePos.X.Offset+delta.X, framePos.Y.Scale, framePos.Y.Offset+delta.Y)
    end
end)
frame.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then
        drag = false
    end
end)

-- 日志输出
local function addLog(msg, color)
    if not LoggingEnabled then return end  -- 关了就不打印

    local l = Instance.new("TextLabel")
    l.Size = UDim2.new(1,0,0,14)
    l.BackgroundTransparency = 1
    l.Text = "["..os.date("%H:%M:%S").."] "..msg
    l.TextColor3 = color or Color3.new(1,1,1)
    l.Font = Enum.Font.Code
    l.TextSize = 10
    l.Parent = logArea
end

-- 日志开关
btnLogToggle.MouseButton1Click:Connect(function()
    LoggingEnabled = not LoggingEnabled
    btnLogToggle.Text = LoggingEnabled and "LOG: ON" or "LOG: OFF"
    btnLogToggle.BackgroundColor3 = LoggingEnabled and Color3.new(0.1,0.4,0.2) or Color3.new(0.3,0.1,0.1)
    addLog(LoggingEnabled and "日志已开启" or "日志已关闭", LoggingEnabled and Color3.new(0,1,0.4) or Color3.new(1,0.4,0.4))
end)

-- 清空日志
btnClearLog.MouseButton1Click:Connect(function()
    for _,v in pairs(logArea:GetChildren()) do
        if v:IsA("TextLabel") then v:Destroy() end
    end
    addLog("日志已清空", Color3.new(0.6,0.6,1))
end)

-- 记录控制台信息
LogService.MessageOut:Connect(function(msg, t)
    if not LoggingEnabled then return end

    if t == Enum.MessageType.MessageError then
        addLog("[ERROR] "..msg, Color3.new(1,0,0))
    elseif t == Enum.MessageType.MessageWarning then
        addLog("[WARN] "..msg, Color3.new(1,1,0))
    elseif t == Enum.MessageType.MessageInfo then
        addLog("[INFO] "..msg, Color3.new(0,1,1))
    elseif t == Enum.MessageType.MessageOutput then
        addLog("[PRINT] "..msg, Color3.new(0.4,0.8,1))
    end
end)

-- 防踢功能
local function enableAK()
    AntiKickActive = true
    pcall(function()
        oldKick = lp.Kick
        lp.Kick = function(...)
            KickAttempts += 1
            addLog("[BLOCKED] Kick attempt #"..KickAttempts, Color3.new(1, 0.5, 0))
            return task.wait(9e9)
        end
    end)

    ancestryConn = lp.AncestryChanged:Connect(function(_, p)
        if p ~= Players then lp.Parent = Players end
    end)

    status.Text = "ANTIKICK: ON | BLOCKED: "..KickAttempts
    status.TextColor3 = Color3.new(0,1,0.4)
    btnAntiKick.Text = "STOP"
    btnAntiKick.BackgroundColor3 = Color3.new(0.6,0,0)
    addLog("防踢已开启", Color3.new(0,1,0.4))
end

local function disableAK()
    AntiKickActive = false
    pcall(function() if oldKick then lp.Kick = oldKick end end)
    if ancestryConn then ancestryConn:Disconnect() end

    status.Text = "ANTIKICK: OFF | BLOCKED: "..KickAttempts
    status.TextColor3 = Color3.new(1,0.2,0.2)
    btnAntiKick.Text = "START"
    btnAntiKick.BackgroundColor3 = Color3.new(0.2,0.3,0.4)
    addLog("防踢已关闭", Color3.new(1,0.2,0.2))
end

btnAntiKick.MouseButton1Click:Connect(function()
    if AntiKickActive then disableAK() else enableAK() end
end)

addLog("控制台已加载 · 滚动正常", Color3.new(0,1,1))
addLog("新消息不会自动跳到底部", Color3.new(0,1,1))
