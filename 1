-- 完整日志记录 + 防踢（包含蓝色日志）
local Players = game:GetService("Players")
local StarterGui = game:GetService("StarterGui")
local LogService = game:GetService("LogService")
local lp = Players.LocalPlayer

local AntiKickActive = false
local KickAttempts = 0
local oldKick, AncestryConn
local UI = {}

local function CreateConsole()
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "FullLogConsole"
    ScreenGui.ResetOnSpawn = false
    ScreenGui.Parent = lp.PlayerGui

    local ConsoleFrame = Instance.new("Frame")
    ConsoleFrame.Size = UDim2.new(0, 360, 0, 270)
    ConsoleFrame.Position = UDim2.new(0.02, 0, 0.02, 0)
    ConsoleFrame.BackgroundColor3 = Color3.new(0.05,0.05,0.08)
    ConsoleFrame.BorderColor3 = Color3.new(0,0.8,0.3)
    ConsoleFrame.BorderSizePixel = 2
    ConsoleFrame.Parent = ScreenGui

    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(1,0,0,25)
    Title.BackgroundColor3 = Color3.new(0,0.8,0.3)
    Title.Text = "Full Log Recorder & AntiKick"
    Title.TextColor3 = Color3.new(0,0,0)
    Title.Font = Enum.Font.Code
    Title.TextSize = 14
    Title.Parent = ConsoleFrame

    local LogFrame = Instance.new("ScrollingFrame")
    LogFrame.Size = UDim2.new(1,-10,0.78,-30)
    LogFrame.Position = UDim2.new(0,5,0,30)
    LogFrame.BackgroundTransparency = 1
    LogFrame.ScrollBarThickness = 6
    LogFrame.Parent = ConsoleFrame

    local LogList = Instance.new("UIListLayout")
    LogList.Parent = LogFrame
    LogList.SortOrder = Enum.SortOrder.LayoutOrder
    LogList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        LogFrame.CanvasSize = UDim2.new(0,0,LogList.AbsoluteContentSize.Y,0)
        LogFrame.CanvasPosition = Vector2.new(0, 9e9)
    end)

    local Status = Instance.new("TextLabel")
    Status.Size = UDim2.new(0.7,0,0.1,0)
    Status.Position = UDim2.new(0,5,0.85,0)
    Status.BackgroundTransparency = 1
    Status.Text = "STATUS: OFFLINE"
    Status.TextColor3 = Color3.new(1,0.3,0.3)
    Status.Font = Enum.Font.Code
    Status.TextSize = 12
    Status.Parent = ConsoleFrame

    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(0.25,0,0.1,0)
    Btn.Position = UDim2.new(0.7,0,0.85,0)
    Btn.BackgroundColor3 = Color3.new(0.3,0.3,0.3)
    Btn.BorderColor3 = Color3.new(0,0.8,0.3)
    Btn.Text = "START"
    Btn.TextColor3 = Color3.new(1,1,1)
    Btn.Font = Enum.Font.Code
    Btn.TextSize = 12
    Btn.Parent = ConsoleFrame

    -- 拖拽
    local drag, start, pos
    ConsoleFrame.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            drag = true start = i.Position pos = ConsoleFrame.Position
        end
    end)
    ConsoleFrame.InputChanged:Connect(function(i)
        if drag then
            local d = i.Position - start
            ConsoleFrame.Position = UDim2.new(pos.X.Scale, pos.X.Offset+d.X, pos.Y.Scale, pos.Y.Offset+d.Y)
        end
    end)
    ConsoleFrame.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
    end)

    UI = {LogFrame=LogFrame, Status=Status, Btn=Btn}
end

local function AddLog(msg, color)
    local l = Instance.new("TextLabel")
    l.Size = UDim2.new(1,0,0,14)
    l.BackgroundTransparency = 1
    l.Text = "["..os.date("%H:%M:%S").."] "..msg
    l.TextColor3 = color or Color3.new(1,1,1)
    l.Font = Enum.Font.Code
    l.TextSize = 10
    l.Parent = UI.LogFrame
end

-- 监听所有日志（包括蓝色）
local function StartLog()
    LogService.MessageOut:Connect(function(msg, typ)
        if typ == Enum.MessageType.MessageError then
            AddLog("[ERROR] "..msg, Color3.new(1,0,0))
        elseif typ == Enum.MessageType.MessageWarning then
            AddLog("[WARN] "..msg, Color3.new(1,1,0))
        elseif typ == Enum.MessageType.MessageInfo then
            AddLog("[INFO] "..msg, Color3.new(0,1,1)) -- 蓝色
        elseif typ == Enum.MessageType.MessageOutput then
            AddLog("[PRINT] "..msg, Color3.new(0.4,0.8,1)) -- 亮蓝
        end
    end)
    AddLog("Log recorder started (all colors)", Color3.new(0,1,0))
end

local function EnableAntiKick()
    if AntiKickActive then return end
    AntiKickActive = true

    pcall(function()
        oldKick = lp.Kick
        lp.Kick = function(...)
            KickAttempts += 1
            AddLog("[ANTIKICK] Blocked kick #"..KickAttempts, Color3.new(1,0.5,0))
            StarterGui:SetCore("SendNotification",{
                Title="Kick Blocked", Text="Attempt "..KickAttempts, Duration=2
            })
            return task.wait(math.huge)
        end
    end)

    AncestryConn = lp.AncestryChanged:Connect(function(_,p)
        if p ~= Players then lp.Parent = Players end
    end)

    UI.Status.Text = "STATUS: ONLINE | BLOCKED: "..KickAttempts
    UI.Status.TextColor3 = Color3.new(0,1,0)
    UI.Btn.Text = "STOP"
    UI.Btn.BackgroundColor3 = Color3.new(1,0.2,0.2)
    AddLog("AntiKick enabled", Color3.new(0,1,0))
end

local function DisableAntiKick()
    if not AntiKickActive then return end
    AntiKickActive = false

    pcall(function() if oldKick then lp.Kick = oldKick end end)
    if AncestryConn then AncestryConn:Disconnect() end

    UI.Status.Text = "STATUS: OFFLINE | BLOCKED: "..KickAttempts
    UI.Status.TextColor3 = Color3.new(1,0.3,0.3)
    UI.Btn.Text = "START"
    UI.Btn.BackgroundColor3 = Color3.new(0.3,0.3,0.3)
    AddLog("AntiKick disabled", Color3.new(1,0.3,0.3))
end

CreateConsole()
StartLog()
AddLog("UI loaded. Press START to enable anti-kick.", Color3.new(0.8,0.8,0.8))

UI.Btn.MouseButton1Click:Connect(function()
    if AntiKickActive then DisableAntiKick() else EnableAntiKick() end
end)
