-- 手机最终版 · 防踢+日志自动滚动+隐藏可打开+无多余行
local Players = game:GetService("Players")
local StarterGui = game:GetService("StarterGui")
local LogService = game:GetService("LogService")
local lp = Players.LocalPlayer

local AntiKickActive = false
local KickAttempts = 0
local oldKick, ancestryConn
local ConsoleVisible = true

-- 主界面
local sg = Instance.new("ScreenGui")
sg.Name = "Console"
sg.ResetOnSpawn = false
sg.Parent = lp.PlayerGui

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 320, 0, 270)
frame.Position = UDim2.new(0.02, 0, 0.02, 0)
frame.BackgroundColor3 = Color3.new(0.07,0.07,0.12)
frame.BorderColor3 = Color3.new(0, 0.7, 1)
frame.BorderSizePixel = 2
frame.Parent = sg

-- 标题
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1,0,0,26)
title.BackgroundColor3 = Color3.new(0, 0.7, 1)
title.Text = "CONSOLE & ANTIKICK"
title.TextColor3 = Color3.new(0,0,0)
title.Font = Enum.Font.Code
title.TextSize = 14
title.Parent = frame

-- 日志区域
local logArea = Instance.new("ScrollingFrame")
logArea.Size = UDim2.new(1,-10,0.65,-26)
logArea.Position = UDim2.new(0,5,0,26)
logArea.BackgroundTransparency = 1
logArea.ScrollBarThickness = 6
logArea.ScrollingEnabled = true
logArea.Parent = frame

local list = Instance.new("UIListLayout")
list.Parent = logArea
list.SortOrder = Enum.SortOrder.LayoutOrder
list.Padding = UDim.new(0, 2)

list:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
    logArea.CanvasSize = UDim2.new(0, 0, list.AbsoluteContentSize.Y + 20, 0)
    -- 自动滚动到底（你要的）
    logArea.CanvasPosition = Vector2.new(0, logArea.AbsoluteCanvasSize.Y)
end)

-- 状态
local status = Instance.new("TextLabel")
status.Size = UDim2.new(1,-10,0.09,0)
status.Position = UDim2.new(0,5,0.7,0)
status.BackgroundTransparency = 1
status.Text = "ANTIKICK: OFF"
status.TextColor3 = Color3.new(1,0.2,0.2)
status.Font = Enum.Font.Code
status.TextSize = 13
status.Parent = frame

-- 防踢按钮
local btnToggle = Instance.new("TextButton")
btnToggle.Size = UDim2.new(0.42,0,0.14,0)
btnToggle.Position = UDim2.new(0.05,0,0.8,0)
btnToggle.BackgroundColor3 = Color3.new(0.2,0.3,0.4)
btnToggle.Text = "ANTIKICK"
btnToggle.TextColor3 = Color3.new(1,1,1)
btnToggle.Font = Enum.Font.Code
btnToggle.TextSize = 13
btnToggle.Parent = frame

-- 隐藏控制台按钮
local btnShowHide = Instance.new("TextButton")
btnShowHide.Size = UDim2.new(0.42,0,0.14,0)
btnShowHide.Position = UDim2.new(0.53,0,0.8,0)
btnShowHide.BackgroundColor3 = Color3.new(0.1,0.4,0.2)
btnShowHide.Text = "HIDE"
btnShowHide.TextColor3 = Color3.new(1,1,1)
btnShowHide.TextSize = 13
btnShowHide.Parent = frame

-- 悬浮打开按钮
local floatBtn = Instance.new("TextButton")
floatBtn.Size = UDim2.new(0, 70, 0, 40)
floatBtn.Position = UDim2.new(0.02, 0, 0.85, 0)
floatBtn.BackgroundColor3 = Color3.new(0, 0.7, 1)
floatBtn.Text = "OPEN"
floatBtn.TextColor3 = Color3.new(1,1,1)
floatBtn.Font = Enum.Font.Code
floatBtn.TextSize = 14
floatBtn.Visible = false
floatBtn.Parent = sg

-- 拖动窗口
local drag, dragStart, pos
frame.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        drag = true
        dragStart = i.Position
        pos = frame.Position
    end
end)
frame.InputChanged:Connect(function(i)
    if drag and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
        local delta = i.Position - dragStart
        frame.Position = UDim2.new(pos.X.Scale, pos.X.Offset+delta.X, pos.Y.Scale, pos.Y.Offset+delta.Y)
    end
end)
frame.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        drag = false
    end
end)

-- 日志：来一条加一行
local function addLog(msg, color)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1,0,0,14)
    label.BackgroundTransparency = 1
    label.Text = "["..os.date("%H:%M:%S").."] "..msg
    label.TextColor3 = color or Color3.new(1,1,1)
    label.Font = Enum.Font.Code
    label.TextSize = 10
    label.Parent = logArea
end

-- 显示 / 隐藏
btnShowHide.MouseButton1Click:Connect(function()
    ConsoleVisible = not ConsoleVisible
    frame.Visible = ConsoleVisible
    floatBtn.Visible = not ConsoleVisible
    btnShowHide.Text = ConsoleVisible and "HIDE" or "SHOW"
end)

-- 打开
floatBtn.MouseButton1Click:Connect(function()
    ConsoleVisible = true
    frame.Visible = true
    floatBtn.Visible = false
    btnShowHide.Text = "HIDE"
end)

-- 日志监听
LogService.MessageOut:Connect(function(msg, t)
    if t == Enum.MessageType.MessageError then
        addLog("[ERROR] "..msg, Color3.new(1,0,0))
    elseif t == Enum.MessageType.MessageWarning then
        addLog("[WARN] "..msg, Color3.new(1,1,0))
    elseif t == Enum.MessageType.MessageInfo then
        addLog("[INFO] "..msg, Color3.new(0,1,1))
    elseif t == Enum.MessageType.MessageOutput then
        addLog("[PRINT] "..msg, Color3.new(0.4,0.8,1))
    end
end)

-- 防踢
local function enableAK()
    AntiKickActive = true
    pcall(function()
        oldKick = lp.Kick
        lp.Kick = function(...)
            KickAttempts += 1
            addLog("[BLOCKED] Kick #"..KickAttempts, Color3.new(1,0.5,0))
            return task.wait(9e9)
        end
    end)

    ancestryConn = lp.AncestryChanged:Connect(function(_, p)
        if p ~= Players then lp.Parent = Players end
    end)

    status.Text = "ANTIKICK: ON | BLOCKED: "..KickAttempts
    status.TextColor3 = Color3.new(0,1,0.4)
    btnToggle.BackgroundColor3 = Color3.new(0.7,0,0)
end

local function disableAK()
    AntiKickActive = false
    pcall(function() if oldKick then lp.Kick = oldKick end end)
    if ancestryConn then ancestryConn:Disconnect() end

    status.Text = "ANTIKICK: OFF | BLOCKED: "..KickAttempts
    status.TextColor3 = Color3.new(1,0.2,0.2)
    btnToggle.BackgroundColor3 = Color3.new(0.2,0.3,0.4)
end

btnToggle.MouseButton1Click:Connect(function()
    if AntiKickActive then disableAK() else enableAK() end
end)
