    floatOpen.Visible = false
end)

-- 日志监听
LogService.MessageOut:Connect(function(msg, msgType)
    if msgType == Enum.MessageType.MessageOutput then
        addLog(msg, "print", Color3.new(0.9,0.9,0.9))
    elseif msgType == Enum.MessageType.MessageInfo then
        addLog(msg, "info", Color3.new(0.2,0.8,1))
    elseif msgType == Enum.MessageType.MessageWarning then
        addLog(msg, "warn", Color3.new(1,0.8,0.2))
    elseif msgType == Enum.MessageType.MessageError then
        addLog(msg, "error", Color3.new(1,0.3,0.3))
    end
end)

-- 防踢
local function enableAK()
    AntiKickActive = true
    pcall(function()
        oldKick = lp.Kick
        lp.Kick = function(...)
            KickAttempts += 1
            addLog("Blocked kick", "antikick", Color3.new(1,0.5,0.1))
            return task.wait(9e9)
        end
    end)
    ancestryConn = lp.AncestryChanged:Connect(function(_, p)
        if p ~= Players then lp.Parent = Players end
    end)
    akStatus.Text = "ANTIKICK: ON | "..KickAttempts
    akStatus.TextColor3 = Color3.new(0.2,1,0.4)
    btnAK.Text = "DISABLE"
    btnAK.BackgroundColor3 = Color3.new(0.35,0.15,0.15)
end

local function disableAK()
    AntiKickActive = false
    pcall(function() if oldKick then lp.Kick = oldKick end end)
    if ancestryConn then ancestryConn:Disconnect() end
    akStatus.Text = "ANTIKICK: OFF | "..KickAttempts
    akStatus.TextColor3 = Color3.new(0.9,0.3,0.3)
    btnAK.Text = "ENABLE"
    btnAK.BackgroundColor3 = Color3.new(0.18,0.25,0.35)
end

btnAK.MouseButton1Click:Connect(function()
    if AntiKickActive then disableAK() else enableAK() end
end)

addLog("Dex++ Console loaded", "info", Color3.new(0.3,1,0.7))
