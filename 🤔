-- 低检测防踢 | Rayfield 纯净版（无namecall）
getgenv().SecureMode = true -- 关键：降低 Rayfield 特征

local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()
local Players = game:GetService("Players")
local TeleportService = game:GetService("TeleportService")
local lp = Players.LocalPlayer

-- 恢复变量，方便开关
local KickHooked = false
local oldKick
local charConn, ancestryConn, teleportConn

-- 创建窗口
local Window = Rayfield:CreateWindow({
    Name = "Secure Anti-Kick",
    LoadingTitle = "Initializing",
    LoadingSubtitle = "Low-Detect Mode",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "SecureAntiKick"
    },
    KeySystem = false
})

local MainTab = Window:CreateTab("Control", 4483362458)

-- 防踢开关
MainTab:CreateToggle({
    Name = "🛡️ 开启防踢防护",
    CurrentValue = false,
    Callback = function(Value)
        if Value then
            -- 替换Kick函数（不用namecall）
            oldKick = lp.Kick
            lp.Kick = function(self, ...)
                return task.wait(9e9)
            end
            KickHooked = true

            -- 角色重载保护
            charConn = lp.CharacterRemoving:Connect(function()
                task.wait(0.3)
                if lp.Parent then lp:LoadCharacter() end
            end)

            -- 父级移除保护
            ancestryConn = lp.AncestryChanged:Connect(function(_, parent)
                if parent ~= Players then lp.Parent = Players end
            end)

            -- 传送保护
            teleportConn = lp.OnTeleport:Connect(function(state)
                if state == Enum.TeleportState.Started then
                    task.wait(0.3)
                    TeleportService:Teleport(game.PlaceId, lp)
                end
            end)

            Rayfield:Notify({
                Title = "Protected",
                Content = "Anti-Kick activated (no namecall)",
                Duration = 3
            })
        else
            -- 恢复Kick函数
            if oldKick then
                lp.Kick = oldKick
            end
            KickHooked = false

            -- 断开所有连接
            if charConn then charConn:Disconnect() end
            if ancestryConn then ancestryConn:Disconnect() end
            if teleportConn then teleportConn:Disconnect() end

            Rayfield:Notify({
                Title = "Disabled",
                Content = "Anti-Kick turned off",
                Duration = 3
            })
        end
    end
})

-- 一键清理（可选）
MainTab:CreateButton({
    Name = "🧹 一键重置状态",
    Callback = function()
        -- 强制恢复所有保护
        if oldKick then lp.Kick = oldKick end
        KickHooked = false
        if charConn then charConn:Disconnect() end
        if ancestryConn then ancestryConn:Disconnect() end
        if teleportConn then teleportConn:Disconnect() end

        Rayfield:Notify({
            Title = "Reset",
            Content = "All protections reset",
            Duration = 3
        })
    end
})

MainTab:CreateLabel("Features:")
MainTab:CreateLabel("• Direct Kick Override (no namecall)")
MainTab:CreateLabel("• Character Reload Protection")
MainTab:CreateLabel("• Ancestry Protection")
MainTab:CreateLabel("• Teleport Protection")

Rayfield:Notify({
    Title = "Loaded",
    Content = "Secure Anti-Kick ready",
    Duration = 3
})
