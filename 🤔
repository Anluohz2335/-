-- 防踢核心逻辑
local function EnableAntiKick()
    if KickHooked then return end
    KickHooked = true

    -- 替换Kick函数（不碰namecall）
    local oldKick
    oldKick = lp.Kick
    lp.Kick = function(self, ...)
        return task.wait(9e9)
    end

    -- 角色重载保护
    CharacterConnection = lp.CharacterRemoving:Connect(function()
        task.wait(0.3)
        if lp.Parent then lp:LoadCharacter() end
    end)

    -- 父级移除保护
    AncestryConnection = lp.AncestryChanged:Connect(function(_, parent)
        if parent ~= Players then lp.Parent = Players end
    end)

    -- 传送保护
    TeleportConnection = lp.OnTeleport:Connect(function(state)
        if state == Enum.TeleportState.Started then
            task.wait(0.3)
            TeleportService:Teleport(game.PlaceId, lp)
        end
    end)

    -- 更新UI
    ToggleButton.Text = "点击关闭"
    ToggleButton.BackgroundColor3 = Color3.new(0.2, 0.6, 0.4)
    StatusLabel.Text = "状态: 已开启 ✅"
    StatusLabel.TextColor3 = Color3.new(0.3, 1, 0.5)

    StarterGui:SetCore("SendNotification", {
        Title = "防踢已开启",
        Text = "低检测模式运行中",
        Duration = 3
    })
end

local function DisableAntiKick()
    if not KickHooked then return end
    KickHooked = false

    -- 恢复原始Kick函数
    lp.Kick = oldKick

    -- 断开所有连接
    if CharacterConnection then CharacterConnection:Disconnect() end
    if AncestryConnection then AncestryConnection:Disconnect() end
    if TeleportConnection then TeleportConnection:Disconnect() end

    -- 更新UI
    ToggleButton.Text = "点击开启"
    ToggleButton.BackgroundColor3 = Color3.new(0.2, 0.4, 0.6)
    StatusLabel.Text = "状态: 已关闭 ❌"
    StatusLabel.TextColor3 = Color3.new(1, 0.5, 0.5)

    StarterGui:SetCore("SendNotification", {
        Title = "防踢已关闭",
        Text = "恢复正常状态",
        Duration = 3
    })
end

-- 按钮点击事件
ToggleButton.MouseButton1Click:Connect(function()
    AntiKickEnabled = not AntiKickEnabled
    if AntiKickEnabled then
        EnableAntiKick()
    else
        DisableAntiKick()
    end
end)

-- 窗口拖拽功能（可选，方便移动）
local dragging = false
local dragStart
local startPos

MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
    end
end)

MainFrame.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

MainFrame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

-- 加载完成提示
StarterGui:SetCore("SendNotification", {
    Title = "UI加载完成",
    Text = "低检测防踢就绪",
    Duration = 3
})
